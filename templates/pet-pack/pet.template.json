{
  "id": "my-companion",
  "name": "My Companion",
  "version": 1,
  "cellWidth": 192,
  "cellHeight": 208,
  "frameCount": 8,
  "sprite": "spritesheet.png",
  "source": "source.png",
  "animations": {
    "idle": {
      "row": 0,
      "frames": 8,
      "fps": 4
    },
    "running-right": {
      "row": 1,
      "frames": 8,
      "fps": 5
    },
    "running-left": {
      "row": 2,
      "frames": 8,
      "fps": 5
    },
    "waving": {
      "row": 3,
      "frames": 8,
      "fps": 5
    },
    "jumping": {
      "row": 4,
      "frames": 8,
      "fps": 7,
