    "landing-hard": {
      "row": 12,
      "frames": 8,
      "fps": 4,
      "loop": false
    },
    "codex-attention": {
      "row": 13,
      "frames": 8,
      "fps": 3.2
    },
    "github-action": {
      "row": 14,
      "frames": 8,
      "fps": 4
    },
    "slack-message": {
      "row": 15,
      "frames": 8,
      "fps": 4
    },
    "slack-send": {
      "row": 16,
      "frames": 8,
      "fps": 4
    }
  },
  "runtime": {
    "defaultScale": 1.0,
    "walkSpeed": 0.9,
    "groundPadding": 24,
    "dragAnchor": {
      "xRatio": 0.5,
      "yRatio": 0.12
    },
    "codexBubble": {
      "enabled": true,
      "session": "current",
      "sprite": "assets/thought-bubble/cyber-thought-bubble-spritesheet.png",
      "frames": 18,
      "openFrames": 5,
      "loopFrames": 8,
      "closeFrames": 5,
      "fps": 9,
      "width": 560,
      "height": 300,
      "attentionAnimation": "codex-attention",
      "approvalBridgeEnabled": true,
      "minimizedDotsHeadroom": 34
    },
    "codexUsage": {
      "enabled": true,
      "session": "current",
      "sprite": "assets/usage-meter/cyber-usage-sign-spritesheet.png",
      "baseFrame": "assets/usage-meter/cyber-usage-sign-frame.png",
      "frames": 18,
      "openFrames": 5,
      "loopFrames": 8,
      "closeFrames": 5,
      "fps": 9,
      "width": 620,
      "height": 420
    },
    "aiProviders": {
      "claude": {
        "enabled": false,
        "model": "claude-sonnet-4-6",
        "maxTokens": 4096
      },
      "github": {
        "enabled": true,
        "remote": "origin",
        "mainBranch": "main",
        "requireCleanTree": true,
        "actionAnimation": "github-action"
      },
      "slack": {
        "enabled": false,
        "sendAs": "bot",
        "transcriptEnabled": true,
        "transcriptDir": "runtime-slack",
        "contacts": [],
        "pollEnabled": false,
        "messageAnimation": "slack-message",
        "sendAnimation": "slack-send"
      }
    },
    "workDrop": {
      "enabled": true,
      "defaultProvider": "codex",
      "defaultSandbox": "read-only",
      "bubbleReplySandbox": "workspace-write",
      "promptAnimation": "review",
      "replyAnimation": "review",
      "bubbleReplyEnabled": true,
      "outputDir": "runtime-work"
    },
    "companions": {
      "enabled": false,
      "menuLabel": "Companions",
      "entries": [
        {
          "id": "sidekick",
          "label": "Sidekick",
          "pet": "sidekick",
          "scale": 1.0,
          "speed": 0.9,
          "codexSession": "off",
          "codexTerminal": {
            "enabled": false,
            "title": "Sidekick Codex",
            "cwd": ".",
            "sandbox": "workspace-write",
            "approvalPolicy": "untrusted",
            "noAltScreen": true
          }
        }
      ]
    }
  },
  "hatch": {
    "template": "public-pet-pack-template",
    "notes": "Copy this manifest into a pet folder and update animation rows to match the sprite atlas you generate."
  }
}
