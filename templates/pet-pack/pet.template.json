      "row": 5,
      "frames": 8,
      "fps": 4,
      "loop": false
    },
    "waiting": {
      "row": 6,
      "frames": 8,
      "fps": 4
    },
    "happy": {
      "row": 6,
      "frames": 8,
      "fps": 4
    },
    "review": {
      "row": 7,
      "frames": 8,
      "fps": 3
    },
    "sitting": {
      "row": 8,
      "frames": 8,
      "fps": 2.5
    },
    "resting": {
      "row": 8,
      "frames": 8,
      "fps": 2.5
    },
    "work-laptop": {
      "row": 8,
      "frames": 8,
      "fps": 2.5
    },
    "picked-up": {
      "row": 9,
      "frames": 8,
      "fps": 4
    },
    "falling": {
      "row": 10,
      "frames": 8,
