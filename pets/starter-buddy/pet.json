{
  "id": "starter-buddy",
  "name": "Starter Buddy",
  "version": 1,
  "cellWidth": 192,
  "cellHeight": 208,
  "frameCount": 8,
  "sprite": "spritesheet.png",
  "source": "source.png",
  "animations": {
    "idle": {
      "row": 0,
      "frames": 8,
      "fps": 4
    },
    "running-right": {
      "row": 1,
      "frames": 8,
      "fps": 5
    },
    "running-left": {
      "row": 2,
      "frames": 8,
      "fps": 5
    },
    "waving": {
      "row": 3,
      "frames": 8,
      "fps": 5
    },
    "jumping": {
      "row": 4,
      "frames": 8,
      "fps": 7,
      "loop": false
    },
    "failed": {
      "row": 5,
      "frames": 8,
      "fps": 4,
      "loop": false
    },
    "waiting": {
      "row": 6,
      "frames": 8,
      "fps": 4
    },
    "happy": {
      "row": 6,
      "frames": 8,
      "fps": 4
    },
    "running": {
      "row": 7,
      "frames": 8,
      "fps": 5
    },
    "review": {
      "row": 8,
      "frames": 8,
      "fps": 3
    },
    "sitting": {
      "row": 9,
      "frames": 8,
      "fps": 2.5
    },
    "resting": {
      "row": 9,
      "frames": 8,
      "fps": 2.5
    },
    "work-laptop": {
      "row": 9,
      "frames": 8,
      "fps": 2.5
    },
    "picked-up": {
      "row": 10,
      "frames": 8,
      "fps": 4
    },
    "falling": {
      "row": 11,
      "frames": 8,
      "fps": 5,
      "loop": false
    },
    "landing-soft": {
      "row": 12,
      "frames": 8,
      "fps": 5,
      "loop": false
    },
    "landing-hard": {
      "row": 13,
      "frames": 8,
      "fps": 4,
      "loop": false
    }
  },
  "runtime": {
    "defaultScale": 1.0,
    "walkSpeed": 0.9,
    "groundPadding": 24,
    "dragAnchor": {
      "xRatio": 0.5,
      "yRatio": 0.12
    },
    "falling": {
      "gravity": 1.2,
      "maxVelocity": 18.0,
      "hardDropHeight": 300,
      "softLandingTicks": 50,
      "hardLandingTicks": 76,
      "landingHoldTicks": 12,
      "postLandingCooldownTicks": 24,
      "gliderEnabled": false
    },
    "ceilingHold": {
      "enabled": false
    },
    "codexBubble": {
      "enabled": true,
      "session": "current",
      "sprite": "assets/thought-bubble/cyber-thought-bubble-spritesheet.png",
      "frames": 18,
      "openFrames": 5,
      "loopFrames": 8,
      "closeFrames": 5,
      "fps": 9,
      "width": 560,
      "height": 300,
      "attentionAnimation": "waiting",
      "approvalBridgeEnabled": true,
      "minimizedDotsHeadroom": 34
    },
    "codexUsage": {
      "enabled": true,
      "session": "current",
      "sprite": "assets/usage-meter/cyber-usage-sign-spritesheet.png",
      "baseFrame": "assets/usage-meter/cyber-usage-sign-frame.png",
      "frames": 18,
      "openFrames": 5,
      "loopFrames": 8,
      "closeFrames": 5,
      "fps": 9,
      "openSeconds": 1.2,
      "closeSeconds": 1.15,
      "width": 620,
      "height": 420,
      "activationDelayMs": 520,
      "intervalMinutes": 30,
      "startupDelaySeconds": 90,
      "visibleSeconds": 12
    },
    "aiProviders": {
      "claude": {
        "enabled": false,
        "model": "claude-sonnet-4-6",
        "maxTokens": 4096
      },
      "github": {
        "enabled": true,
        "remote": "origin",
        "mainBranch": "main",
        "requireCleanTree": true,
        "actionAnimation": "review"
      },
      "slack": {
        "enabled": false,
        "sendAs": "bot",
        "transcriptEnabled": true,
        "transcriptDir": "runtime-slack",
        "contacts": [],
        "pollEnabled": false
      }
    },
    "workDrop": {
      "enabled": true,
      "defaultProvider": "codex",
      "defaultSandbox": "read-only",
      "bubbleReplySandbox": "workspace-write",
      "promptAnimation": "review",
      "receiveAnimation": "picked-up",
      "inspectAnimation": "review",
      "reviewAnimation": "review",
      "laptopAnimation": "work-laptop",
      "replyStartAnimation": "waving",
      "replyAnimation": "review",
      "bubbleReplyEnabled": true,
      "restEnterAnimation": "resting",
      "restAnimation": "resting",
      "sleepPulse": true,
      "sleepSnoozeMarks": true,
      "restOnLimitExhausted": true,
      "outputDir": "runtime-work",
      "statusHoldSeconds": 28
    }
  },
  "hatch": {
    "template": "public-starter",
    "notes": "Starter Buddy is a small permissive demo pet so the public repo runs immediately. Replace it with a generated pet pack for real use."
  }
}
